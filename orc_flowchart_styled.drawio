<mxfile host="app.diagrams.net">
  <diagram name="ORC Flowchart - Styled">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- START -->
        <mxCell id="2" value="Start" style="rounded=1;arcSize=50;fillColor=#F5F7FA;strokeColor=#2F3B52;fontColor=#1F2933;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="20" width="150" height="36" as="geometry"/>
        </mxCell>

        <!-- Process -->
        <mxCell id="3" value="Load &amp; validate config" style="rounded=1;fillColor=#E6EEF5;strokeColor=#2F3B52;fontColor=#1F2933;" vertex="1" parent="1">
          <mxGeometry x="150" y="80" width="200" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="4" value="Init fluid &amp; components" style="rounded=1;fillColor=#E6EEF5;strokeColor=#2F3B52;fontColor=#1F2933;" vertex="1" parent="1">
          <mxGeometry x="150" y="152" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="6" value="Dry fluid?" style="rhombus;fillColor=#F2F2F2;strokeColor=#2F3B52;fontColor=#1F2933;" vertex="1" parent="1">
          <mxGeometry x="175" y="230" width="150" height="56" as="geometry"/>
        </mxCell>

        <!-- Error -->
        <mxCell id="7" value="Error" style="rounded=1;fillColor=#FDECEA;strokeColor=#C00000;fontColor=#7A0000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="245" width="80" height="30" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="22" value="Export report" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2F3B52;fontColor=#1F2933;" vertex="1" parent="1">
          <mxGeometry x="150" y="320" width="200" height="34" as="geometry"/>
        </mxCell>

        <!-- END -->
        <mxCell id="23" value="End" style="rounded=1;arcSize=50;fillColor=#F5F7FA;strokeColor=#2F3B52;fontColor=#1F2933;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="380" width="150" height="36" as="geometry"/>
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F3B52;strokeWidth=1.5;endArrow=block;" edge="1" source="2" target="3" parent="1"/>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F3B52;strokeWidth=1.5;endArrow=block;" edge="1" source="3" target="4" parent="1"/>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F3B52;strokeWidth=1.5;endArrow=block;" edge="1" source="4" target="6" parent="1"/>
        <mxCell id="e4" value="No" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F3B52;strokeWidth=1.5;endArrow=block;" edge="1" source="6" target="7" parent="1"/>
        <mxCell id="e5" value="Yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F3B52;strokeWidth=1.5;endArrow=block;" edge="1" source="6" target="22" parent="1"/>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F3B52;strokeWidth=1.5;endArrow=block;" edge="1" source="22" target="23" parent="1"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
